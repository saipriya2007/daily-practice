#include <iostream>
using namespace std;

int main()
{
    int m;
    int n;
    int a[100][100];
    int b[100][100];

    cout<<"m";
    cout<<endl;
    cin>>m;
    cout<<"n";
    cout<<endl;
    cin>>n;




    cout<<"a";
    cout<<endl;

    for(int i=0; i<m;i++)
    {
        for(int j=0;j<n ;j++)
        {
            cin>>a[i][j];
            cout<<endl;
        }
    }



    cout<<"b";
    cout<<endl;

    for(int i=0; i<m;i++)
    {
        for(int j=0;j<n ;j++)
        {
            cin>>b[i][j];
            cout<<endl;
        }
    }



    cout<<"sum is";
    cout<<endl;

    int sum[100][100];
    for(int i=0; i<m;i++)
    {
        for(int j=0;j<n ;j++)
        {
           sum[i][j]=a[i][j]+b[i][j];
        }
    }



    for(int i=0; i<m;i++)
    {
        for(int j=0;j<n ;j++)
        {
            cout<<sum[i][j]<<"  ";

        }
        cout<<endl;
    }



    cout<<endl;
    system("pause");
    return 0;
}
