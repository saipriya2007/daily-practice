#include<iostream>
using namespace std;

class box
{
private:
    static int length;
    static int width;

public:
    box (int l, int w)
    {
        length = new  (l);
        width = new  (w);

        cout<<"value l is "<<*length<<endl;
        cout<<"value w is "<<*width<<endl;
    }

    static void show()
    {
        cout<<"value l is "<<*length<<endl;
        cout<<"value w is "<<*width<<endl;
    }

    ~box()
    {
        delete length();
        cout<<"length is released"<<endl;
        cout<<"width is released"<<endl;
    }
};


int box ::length=10;
int box ::width=20;


int main()
{
    box b;
    b.show();

    cout<<endl;
    cout<<endl;

    box::show()

    cout<<endl;
    system("pause");

    return 0;
}
