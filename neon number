#include <iostream>
#include <cmath>
using namespace std;

int main()
{
    int x;
    cout<<"enter a number ";
    cin>>x;

    int a;
    int sum = 0;

    a = x*x;

    while (a!=0)
    {
        sum += a%10;
        a /= 10;
    }

    int root = sqrt (sum);

    if(root * root == sum)
    {cout<<"neon";}
    else
    {cout<<"not";}

    cout<<endl;
    system("pause");

    return 0;
}
