#include <iostream>
#include<cmath>

using namespace std;

int fact(int i)
{
  int z=1;
  for(int j=1;j<=i;j++)
  {
      z *= j;
      //cout<<z;
  }
  return z;
}

int main()
{
    cout<<"for x - 3x/3! + 5x/5! - ..........."<<endl;
    int n;
    int x;

    cout<<"till where you want to execute"<<endl;
    cin>>n;
    cout<<"what's the constant number you want to multiply (x)"<<endl;
    cin>>x;

    float sum=0.0;

    for(int i=1; i<= n; i++)
    {
        float sign=pow((-1),((3*i)-1));
        //cout<<sign<<endl;
        float num=pow(x,((2*i)-1));
        //cout<<num<<endl;
        float denom = fact(2 * i - 1);


       sum = sum + ((sign*num )/denom);

    }
    //cout<<sum;


    cout<<"sum of series is "<<sum<<endl;

    cout<<endl;
    system("pause");

    return 0;

}
